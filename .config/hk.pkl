amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

local init = new Group {
    steps {
        ["init_types_ts"] = new Step {
            glob = "**/*"
            dir = "gatelogue-types-ts"
            check = "pnpm i && pnpm prepare"
        }
        ["init_client"] = new Step {
            depends = List("init_types_ts")
            glob = "**/*"
            dir = "gatelogue-client"
            check = "pnpm i"
        }
        ["copy-sql"] = new Step {
            glob = "gatelogue-types-sql/**/*"
            fix = "gatelogue-types-sql/copy.sh"
        }
    }
}

local formatters = new Mapping<String, Step> {
    ["hatch_format"] = (Builtins.ruff_format) {
        workspace_indicator = "pyproject.toml"
        check = "cd {{ workspace }} && hatch check fmt -- --force-exclude {{ workspace_files }}"
        fix = "cd {{ workspace }} && hatch check fmt --fix -- --force-exclude {{ workspace_files }}"
    }
    ["prettier"] = (Builtins.prettier) {
        depends = List("init")
        workspace_indicator = "package.json"
        check = "cd {{ workspace }} && pnpm run format:check {{ workspace_files }}"
        fix = "cd {{ workspace }} && pnpm run format {{ workspace_files }}"
    }
    ["cargo_fmt"] = Builtins.cargo_fmt
}

local linters = new Mapping<String, Step> {
    ["hatch"] = (Builtins.ruff) {
        workspace_indicator = "pyproject.toml"
        check = "cd {{ workspace }} && hatch check code -- --force-exclude {{ workspace_files }}"
        fix = "cd {{ workspace }} && hatch check code --fix -- --force-exclude {{ workspace_files }}"
    }
    ["eslint"] = (Builtins.eslint) {
        depends = List("init")
        workspace_indicator = "package.json"
        check = "cd {{ workspace }} && pnpm run lint {{ workspace_files }}"
        fix = "cd {{ workspace }} && pnpm run lint:fix {{ workspace_files }}"
    }
    ["cargo_clippy"] = (Builtins.cargo_clippy) {
        check = (Builtins.cargo_clippy.check as String) + " --all-targets --all-features"
        fix = (Builtins.cargo_clippy.fix as String) + " --all-targets --all-features"
    }
    ["zizmor"] = Builtins.zizmor
    ["actionlint"] = Builtins.actionlint
    ["poutine"] {
        glob = Builtins.zizmor.glob
        check = "poutine analyze_local . --skip github_action_from_unverified_creator_used"
    }
    ["shellcheck"] = Builtins.shellcheck
}
local type_checkers = new Mapping<String, Step> {
    ["hatch_type_check"] {
        workspace_indicator = "pyproject.toml"
        glob = Builtins.ruff.glob
        check = "cd {{ workspace }} && hatch check types"
    }
    ["tsc_type_check"] {
        depends = List("init")
        workspace_indicator = "package.json"
        glob = Builtins.eslint.glob
        check = "cd {{ workspace }} && pnpm run type-check"
    }
}
local sarif = new Mapping<String, Step> {
    ["mkdir"] {
        fix = "mkdir .sarif || true"
        exclusive = true
    }
    ["eslint"] {
        depends = List("init")
        workspace_indicator = "package.json"
        fix = "cd {{ workspace }} && pnpm run lint:sarif > ../.sarif/eslint-{{ workspace }}.sarif"
    }
    ["hatch"] {
        workspace_indicator = "pyproject.toml"
        fix = linters["hatch"].fix.replaceAll("{{ workspace_files }}", "") + " --output-format=sarif > ../.sarif/hatch-{{ workspace }}.sarif"
    }
    ["cargo_clippy"] {
        workspace_indicator = "Cargo.toml"
        fix = linters["cargo_clippy"].fix as String + " --message-format=json | clippy-sarif > .sarif/clippy-{{ workspace }}.sarif"
    }
    ["zizmor"] {
        fix = linters["zizmor"].fix.replaceAll("{{ files }}", ".") + " --format=sarif > .sarif/zizmor.sarif"
    }
    ["actionlint"] {
        check = linters["actionlint"].check.replaceAll("{{ files }}", "") + " -format \"$(curl -sSL \"https://raw.githubusercontent.com/rhysd/actionlint/refs/heads/main/testdata/format/sarif_template.txt\")\" > .sarif/actionlint.sarif"
    }
    ["poutine"] {
        check = linters["poutine"].check as String + " --format=sarif > .sarif/poutine.sarif"
    }
    ...type_checkers
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = new Mapping<String, Step | Group> {
            ["init"] = init
            ...formatters
            ...linters
            ...type_checkers
        }
    }
    ["fix"] {
        fix = true
        steps = new Mapping<String, Step | Group> {
            ["init"] = init
            ...formatters
            ...linters
            ...type_checkers
        }
    }
    ["check"] {
        steps = new Mapping<String, Step | Group> {
            ["init"] = init
            ...formatters
            ...linters
            ...type_checkers
        }
    }
    ["format"] {
        fix = true
        steps = new Mapping<String, Step | Group> {
            ["init"] = init
            ...formatters
        }
    }
    ["sarif"] {
        fix = true
        steps = new Mapping<String, Step | Group> {
            ["init"] = init
            ...sarif
        }
    }
}
