{
  "name": "gatelogue-client",
  "version": "3.1.4-rc.4+13",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build --base=/gatelogue",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint ${@:-src/}",
    "lint:fix": "eslint --fix ${@:-src/}",
    "lint:sarif": "eslint -f @microsoft/eslint-formatter-sarif --fix ${@:-src/}",
    "format": "prettier --write ${@:-.}",
    "format:check": "prettier --check ${@:-.}",
    "prepare": "cd ../gatelogue-types-ts && pnpm i && pnpm run prepare"
  },
  "dependencies": {
    "gatelogue-types": "link:../gatelogue-types-ts",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "vue-tippy": "6.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.3",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vite-plugin-vue-devtools": "8.1.5",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.7"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
