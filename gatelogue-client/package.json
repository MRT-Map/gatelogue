{
  "name": "gatelogue-client",
  "version": "3.1.2+13",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build --base=/gatelogue",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "lint:sarif": "eslint -f @microsoft/eslint-formatter-sarif --fix src/",
    "format": "prettier --write .",
    "prepare": "cd ../gatelogue-types-ts && pnpm i && pnpm run prepare"
  },
  "dependencies": {
    "gatelogue-types": "link:../gatelogue-types-ts",
    "vue": "3.5.34",
    "vue-router": "5.0.6",
    "vue-tippy": "6.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.1",
    "globals": "17.6.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vite-plugin-vue-devtools": "8.1.1",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.8"
  },
  "packageManager": "pnpm@11.0.6+sha512.97f906e1da2bedac3df83cadae04b4753a130092dd49d55cd36825ad3e623e9df3f97754f8f259e699172a360fac569acf2f908e7732bdae3eddb2dcf7e121fd"
}
