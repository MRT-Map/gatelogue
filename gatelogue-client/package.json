{
  "name": "gatelogue-client",
  "version": "3.1.4-rc.4+13",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build --base=/gatelogue",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint ${@:-src/}",
    "lint:fix": "eslint --fix ${@:-src/}",
    "lint:sarif": "eslint -f @microsoft/eslint-formatter-sarif --fix ${@:-src/}",
    "format": "prettier --write ${@:-.}",
    "format:check": "prettier --check ${@:-.}",
    "prepare": "cd ../gatelogue-types-ts && pnpm i && pnpm run prepare"
  },
  "dependencies": {
    "gatelogue-types": "link:../gatelogue-types-ts",
    "vue": "3.5.40",
    "vue-router": "5.2.0",
    "vue-tippy": "6.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.3",
    "@vitejs/plugin-vue": "6.0.8",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vite-plugin-vue-devtools": "8.1.5",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.7"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
