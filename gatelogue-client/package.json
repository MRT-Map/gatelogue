{
  "name": "gatelogue-client",
  "version": "3.1.2+13",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build --base=/gatelogue",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "lint:sarif": "eslint -f @microsoft/eslint-formatter-sarif --fix src/",
    "format": "prettier --write .",
    "prepare": "cd ../gatelogue-types-ts && pnpm i && pnpm run prepare"
  },
  "dependencies": {
    "gatelogue-types": "link:../gatelogue-types-ts",
    "vue": "3.5.32",
    "vue-router": "5.0.4",
    "vue-tippy": "6.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.0",
    "globals": "17.5.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.9",
    "vite-plugin-vue-devtools": "8.1.1",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.7"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
