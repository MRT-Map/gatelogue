{
  "name": "gatelogue-client",
  "version": "3.1.4-rc.4+13",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build --base=/gatelogue",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint ${@:-src/}",
    "lint:fix": "eslint --fix ${@:-src/}",
    "lint:sarif": "eslint -f @microsoft/eslint-formatter-sarif --fix ${@:-src/}",
    "format": "prettier --write ${@:-.}",
    "format:check": "prettier --check ${@:-.}",
    "prepare": "cd ../gatelogue-types-ts && pnpm i && pnpm run prepare"
  },
  "dependencies": {
    "gatelogue-types": "link:../gatelogue-types-ts",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "vue-tippy": "6.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.4",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.1",
    "globals": "17.6.0",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.16",
    "vite-plugin-vue-devtools": "8.1.2",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.3.3"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
