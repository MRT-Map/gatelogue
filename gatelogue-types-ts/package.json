{
  "name": "gatelogue-types",
  "version": "3.0.8+12",
  "license": "GPL-3.0-only",
  "author": {
    "name": "MRT Mapping Services",
    "url": "https://github.com/mrt-map"
  },
  "maintainers": [
    {
      "name": "7d",
      "email": "61975820+iiiii7d@users.noreply.github.com"
    }
  ],
  "description": "Types for loading and reading Gatelogue data",
  "repository": "github:MRT-Map/gatelogue",
  "homepage": "https://mrt-map.github.io/gatelogue",
  "bugs": "https://github.com/mrt-map/gatelogue/issues",
  "readme": "README.md",
  "keywords": [
    "gatelogue",
    "mrt",
    "minecart rapid transit"
  ],
  "type": "module",
  "scripts": {
    "test": "run-p build:esm && node test.js",
    "build": "run-p build:*",
    "build:esm": "tsc --outDir dist",
    "build:cjs": "tsc --outDir dist/cjs -m commonjs --verbatimModuleSyntax false --target es2017 --module preserve",
    "lint": "eslint --fix src/*",
    "format": "prettier --write .",
    "doc": "typedoc src/lib.ts",
    "prepare": "run-p build",
    "prepublish": "cp ../README.md .",
    "postpublish": "rm ./README.md"
  },
  "types": "./dist/lib.d.ts",
  "exports": {
    "import": "./dist/lib.js",
    "require": "./dist/cjs/lib.js"
  },
  "files": [
    "dist",
    "tsconfig.json"
  ],
  "dependencies": {
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@total-typescript/tsconfig": "1.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/sql.js": "1.4.9",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
