{
  "name": "gatelogue-types",
  "version": "3.1.2+13",
  "license": "GPL-3.0-only",
  "author": {
    "name": "MRT Mapping Services",
    "url": "https://github.com/mrt-map"
  },
  "maintainers": [
    {
      "name": "7d",
      "email": "61975820+iiiii7d@users.noreply.github.com"
    }
  ],
  "description": "Types for loading and reading Gatelogue data",
  "repository": "github:MRT-Map/gatelogue",
  "homepage": "https://mrt-map.github.io/gatelogue",
  "bugs": "https://github.com/mrt-map/gatelogue/issues",
  "readme": "README.md",
  "keywords": [
    "gatelogue",
    "mrt",
    "minecart rapid transit"
  ],
  "type": "module",
  "scripts": {
    "test": "run-s compile-sql build:esm && node test.js",
    "build": "run-s compile-sql && run-p build:*",
    "build:esm": "tsc --outDir dist",
    "build:cjs": "tsc --outDir dist/cjs -m commonjs --verbatimModuleSyntax false --target es2017 --module preserve",
    "compile-sql": "node compile-sql.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "lint:sarif": "eslint -f @microsoft/eslint-formatter-sarif --fix src/",
    "format": "prettier --write .",
    "doc": "typedoc src/lib.ts",
    "prepare": "run-p build",
    "prepublish": "cp ../README.md .",
    "postpublish": "rm ./README.md"
  },
  "types": "./dist/lib.d.ts",
  "exports": {
    "import": "./dist/lib.js",
    "require": "./dist/cjs/lib.js"
  },
  "files": [
    "dist",
    "tsconfig.json"
  ],
  "dependencies": {
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@total-typescript/tsconfig": "1.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/sql.js": "1.4.11",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
