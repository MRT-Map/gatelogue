{
  "name": "gatelogue-types",
  "version": "3.0.0+12",
  "license": "GPL-3.0-only",
  "author": {
    "name": "MRT Mapping Services",
    "url": "https://github.com/mrt-map"
  },
  "maintainers": [
    {
      "name": "7d",
      "email": "61975820+iiiii7d@users.noreply.github.com"
    }
  ],
  "description": "Types for loading and reading Gatelogue data",
  "repository": "github:MRT-Map/gatelogue",
  "homepage": "https://mrt-map.github.io/gatelogue",
  "bugs": "https://github.com/mrt-map/gatelogue/issues",
  "readme": "README.md",
  "keywords": [
    "gatelogue",
    "mrt",
    "minecart rapid transit"
  ],
  "type": "module",
  "scripts": {
    "test": "pnpm run build:esm && node test.js",
    "build": "pnpm run build:esm && pnpm run build:cjs",
    "build:esm": "tsc --outDir dist",
    "build:cjs": "tsc --outDir dist/cjs -m commonjs --verbatimModuleSyntax false --target es2017 --module preserve",
    "lint": "eslint --fix lib.ts",
    "format": "prettier --write .",
    "doc": "typedoc lib.ts",
    "prepare": "pnpm run build",
    "prepublish": "cp ../README.md .",
    "postpublish": "rm ./README.md"
  },
  "types": "./dist/lib.d.ts",
  "exports": {
    "import": "./dist/lib.js",
    "require": "./dist/cjs/lib.js"
  },
  "files": [
    "dist",
    "tsconfig.json"
  ],
  "dependencies": {
    "sql.js": "1.14.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@total-typescript/tsconfig": "1.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/sql.js": "1.4.9",
    "eslint": "10.0.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}
